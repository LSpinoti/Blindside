{
  "name": "blindside",
  "version": "1.0.0",
  "description": "Blindside private prediction market MVP for Monad and Unlink.",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n api,web \"pnpm dev:api\" \"pnpm dev:web\"",
    "dev:api": "tsx watch server/index.ts",
    "dev:web": "vite",
    "build": "pnpm build:web && pnpm build:api && pnpm build:contracts",
    "build:api": "tsc -p tsconfig.server.json",
    "build:web": "vite build",
    "build:contracts": "\"$HOME/.foundry/bin/forge\" build --root contracts",
    "preview": "vite preview",
    "start:api": "node dist/api/server/index.js",
    "resolve:market": "tsx contracts/script/resolve-market.ts",
    "deploy:market": "bash -lc 'set -a; [ -f .env ] && source .env; set +a; cd contracts && \"$HOME/.foundry/bin/forge\" script script/DeployBlindsideMarkets.s.sol:DeployBlindsideMarketsScript --rpc-url \"${MONAD_RPC_URL:-https://testnet-rpc.monad.xyz}\" --private-key \"$PRIVATE_KEY\" --broadcast --legacy'"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.28.2",
  "dependencies": {
    "@pythnetwork/pyth-sdk-solidity": "^4.3.1",
    "@unlink-xyz/cli": "^0.1.5",
    "@unlink-xyz/core": "^0.1.5",
    "@unlink-xyz/multisig": "^0.1.5",
    "@unlink-xyz/node": "^0.1.5",
    "@unlink-xyz/react": "^0.1.5",
    "@x402/core": "^2.5.0",
    "@x402/evm": "^2.5.0",
    "@x402/express": "^2.5.0",
    "@x402/svm": "^2.5.0",
    "codex": "^0.2.3",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "lightweight-charts": "^5.1.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "viem": "^2.46.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.3.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "concurrently": "^9.2.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1"
  }
}
